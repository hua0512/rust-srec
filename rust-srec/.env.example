# =============================================================================
# Rust-Srec Backend Environment Variables
# =============================================================================
# Copy this file to .env and modify as needed.

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# SQL database connection string
DATABASE_URL=sqlite:./srec.db

# -----------------------------------------------------------------------------
# JWT Configuration (Required for Authentication)
# -----------------------------------------------------------------------------
# Secret key for JWT signing - MUST be at least 32 characters
# Generate with: openssl rand -hex 32
JWT_SECRET=your-secret-key-at-least-32-characters-long

# JWT issuer and audience identifiers (optional)
JWT_ISSUER=rust-srec
JWT_AUDIENCE=rust-srec-api

# Token Expiration (optional, defaults shown)
ACCESS_TOKEN_EXPIRATION_SECS=3600          # 1 hour
REFRESH_TOKEN_EXPIRATION_SECS=604800       # 7 days

# Grace window to tolerate replay of a recently-rotated refresh token (optional)
# Helps with clients that accidentally send the old refresh token again due to
# concurrent refresh attempts/retries. Default: 0 (disabled)
REFRESH_TOKEN_REUSE_GRACE_SECS=10

# Password Policy (optional)
MIN_PASSWORD_LENGTH=8

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# API server port
API_PORT=8080

# API bind address (use 0.0.0.0 to listen on all interfaces)
API_BIND_ADDRESS=0.0.0.0

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Logging level: trace, debug, info, warn, error
RUST_LOG=info

# Log directory (optional)
# LOG_DIR=./logs

# -----------------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------------
# Directory for application data
# DATA_DIR=./data

# Directory for platform configuration files (cookies, etc.)
# CONFIG_DIR=./config

# Output directory for recordings
OUTPUT_DIR=./output

# -----------------------------------------------------------------------------
# Output-root write gate (#508)
# -----------------------------------------------------------------------------
# Comma-separated absolute paths to treat as output-root boundaries for the
# write gate. If unset, the gate auto-discovers mount roots from every
# config layer (global, platform, template, per-streamer). Set explicitly
# to probe additional mounts that aren't yet referenced by any streamer
# config, or to consolidate multiple platform paths under a single gate
# key (e.g. one /rec entry instead of /rec/huya + /rec/douyu + ...).
# OUTPUT_ROOTS example: RUST_SREC_OUTPUT_ROOTS=/rec,/mnt/backup
# RUST_SREC_OUTPUT_ROOTS=

# -----------------------------------------------------------------------------
# Backend locale
# -----------------------------------------------------------------------------
# Locale for backend-emitted notification strings. Currently affects only
# the `output_path_inaccessible` event; other events remain English-only.
# Supported: en, zh-CN. Defaults to en.
# RUST_SREC_LOCALE=en

# -----------------------------------------------------------------------------
# Timezone
# -----------------------------------------------------------------------------
# Container/application timezone
TZ=UTC

# -----------------------------------------------------------------------------
# Proxy Configuration (Optional)
# -----------------------------------------------------------------------------
# HTTP proxy server URL
# HTTP_PROXY=http://proxy.example.com:8080

# HTTPS proxy server URL
# HTTPS_PROXY=http://proxy.example.com:8080

# Comma-separated hosts to bypass proxy
# NO_PROXY=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Browser Notifications (Web Push / VAPID) (Optional)
# -----------------------------------------------------------------------------
# Enable Web Push by generating VAPID keys (base64url, unpadded), e.g.:
#   docker run --rm ghcr.io/hua0512/rust-srec:latest /app/rust-srec-vapid
#   # or: npx --yes web-push generate-vapid-keys
#
# Note: Browsers require HTTPS (or localhost) for push notifications.
# WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=
# WEB_PUSH_VAPID_SUBJECT=mailto:admin@localhost
